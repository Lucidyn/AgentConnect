        { "expr": "ac_tasks_submitted_total", "legendFormat": "submitted", "refId": "A" }
      ],
      "title": "Tasks Submitted",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "id": 2,
      "targets": [
        { "expr": "sum by (status) (ac_tasks_finished_total)", "legendFormat": "{{status}}", "refId": "A" }
      ],
      "title": "Tasks Finished",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "id": 3,
      "targets": [
        { "expr": "ac_queue_active", "legendFormat": "active", "refId": "A" },
        { "expr": "ac_queue_queued", "legendFormat": "queued", "refId": "B" }
      ],
      "title": "Queue Depth",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 4,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, agent) (rate(ac_agent_think_seconds_bucket[5m])))",
          "legendFormat": "{{agent}} p95",
          "refId": "A"
        }
      ],
      "title": "Agent Think Duration p95",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 5,
      "targets": [
        {
          "expr": "sum by (provider, result) (rate(ac_llm_requests_total[5m]))",
          "legendFormat": "{{provider}} {{result}}",
          "refId": "A"
        }
      ],
      "title": "LLM Request Rate",
      "type": "timeseries"
    }
