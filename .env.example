# LLM (optional — agents use rule-based fallback without a key)
# Provider: openai | openai_compatible | anthropic
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
LLM_TIMEOUT_SECONDS=120

# Anthropic (when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Redis Message Bus
REDIS_URL=redis://localhost:6379/0
USE_REDIS=true

# Shared Memory (Qdrant local storage, auto-fallback to in-memory)
QDRANT_PATH=data/qdrant
USE_QDRANT=true

# Tools
GITHUB_TOKEN=

# Server
HOST=0.0.0.0
PORT=8000
# API_KEY=          # when set, all task/message/template APIs require X-API-Key header

# Plugins (comma-separated filter, empty = all from manifest.yaml)
ENABLED_AGENTS=
ENABLED_TOOLS=
# PLUGINS_MANIFEST=plugins/manifest.yaml

# Task queue
MAX_CONCURRENT_TASKS=3

# Message reliability (SQLite outbox + ACK + retry)
MESSAGE_RELIABILITY=true
MESSAGE_MAX_RETRIES=3
MESSAGE_RETRY_INTERVAL=30
MESSAGE_RETRY_GRACE=60
# CLEAR_FAILED_OUTBOX=true   # purge failed outbox rows on server startup
ASSIGNMENT_MAX_RETRIES=1     # sub-task retries before whole task fails
LOOP_MAX_ITERATIONS=3        # reviewer -> producer loop before human approval

# Performance — fast pipeline (fewer LLM calls, shorter outputs)
FAST_MODE=false
FAST_SKIP_PLANNER_LLM=false  # true = skip Planner LLM, use rule-based plan only
FAST_SKIP_RESEARCH=true      # fast_mode: skip Research when possible
FAST_SKIP_TEST_RUNNER=true   # fast_mode: skip TestRunner in fallback plan
ASSIGNMENT_CONTEXT_MAX_CHARS=2000

# Per-role LLM limits (when API key is configured)
LLM_MAX_TOKENS_PLANNER=512
LLM_MAX_TOKENS_RESEARCH=1200
LLM_MAX_TOKENS_WRITER=2000
LLM_MAX_TOKENS_ANALYST=1200
LLM_MAX_TOKENS_CODER=800
LLM_MAX_TOKENS_REVIEWER=300
LLM_TEMPERATURE_PLANNER=0
LLM_TEMPERATURE_DEFAULT=0.7

# Tools & queue
ARXIV_TIMEOUT_SECONDS=6
QUEUE_AVG_TASK_SECONDS=90
ASSIGNMENT_CONTEXT_MAX_CHARS=4000

# API limits
TASK_INPUT_MAX_LENGTH=8000
API_MAX_LIST_LIMIT=100

# Collaboration / negotiation
NEGOTIATION_MAX_ROUNDS=2

# Phase 3 — distributed workers
DISTRIBUTED_WORKERS=false
WORKER_MODE=false
WORKER_AGENT_NAME=
WORKER_AGENTS=
WORKER_STREAM_KEY=ac:assignments
WORKER_RESULT_STREAM_KEY=ac:results
WORKER_CONSUMER_GROUP=ac-workers
WORKER_CONSUMER_NAME=
WORKER_POLL_INTERVAL=2

# Phase 3e — horizontal API replicas + shared Postgres (empty = SQLite)
# DATABASE_URL=postgresql://agent:agent@localhost:5432/agentconnect
DATABASE_URL=
DATABASE_POOL_SIZE=10
API_REPLICA_ID=

# DeepSeek example (OpenAI-compatible):
# LLM_PROVIDER=openai_compatible
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# OPENAI_MODEL=deepseek-v4-flash
# FAST_MODE=true
# FAST_SKIP_PLANNER_LLM=true
