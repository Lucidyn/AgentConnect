# LLM (optional — agents use rule-based fallback without a key)
# Provider: openai | openai_compatible | anthropic
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Anthropic (when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Redis Message Bus
REDIS_URL=redis://localhost:6379/0
USE_REDIS=true

# Shared Memory (Qdrant local storage, auto-fallback to in-memory)
QDRANT_PATH=data/qdrant
USE_QDRANT=true

# MCP Tools
GITHUB_TOKEN=

# Server
HOST=0.0.0.0
PORT=8000
# API_KEY=          # optional — protects POST /tasks, cancel, dead-letter retry

# Plugins (comma-separated filter, empty = all from manifest.yaml)
ENABLED_AGENTS=
ENABLED_TOOLS=
# PLUGINS_MANIFEST=plugins/manifest.yaml

# Task queue
MAX_CONCURRENT_TASKS=3

# Message reliability (SQLite outbox + ACK + retry)
MESSAGE_RELIABILITY=true
MESSAGE_MAX_RETRIES=3
MESSAGE_RETRY_INTERVAL=30
MESSAGE_RETRY_GRACE=60
# CLEAR_FAILED_OUTBOX=true   # purge failed outbox rows on server startup
ASSIGNMENT_MAX_RETRIES=1     # sub-task retries before whole task fails
